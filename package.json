{
  "name": "munchkeen",
  "version": "0.0.0",
  "private": true,
  "description": "Solid-first interactive graph exploration toolkit with Cytoscape.js as the first renderer",
  "keywords": [
    "solid"
  ],
  "bugs": {
    "url": "https://github.com/hatchling13/munchkeen/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Jung Wook Park",
    "email": "me@hatchling.dev"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "types": "./dist/core.d.ts"
    },
    "./cytoscape": {
      "import": {
        "types": "./dist/cytoscape.d.ts",
        "default": "./dist/cytoscape.js"
      },
      "types": "./dist/cytoscape.d.ts"
    }
  },
  "scripts": {
    "dev": "vite serve dev",
    "build": "tsdown",
    "test": "concurrently pnpm:test:*",
    "test:client": "vitest",
    "test:ssr": "pnpm run test:client --mode ssr",
    "prepublishOnly": "pnpm build",
    "format": "oxfmt",
    "lint": "concurrently pnpm:lint:*",
    "lint:code": "oxlint",
    "lint:types": "tsc --noEmit"
  },
  "dependencies": {
    "cytoscape": "^3.33.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "concurrently": "^8.2.2",
    "jsdom": "^24.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rolldown-plugin-solid": "^0.2.1",
    "solid-js": "^1.9.11",
    "tsdown": "^0.21.4",
    "typescript": "^5.4.5",
    "vite": "^8.0.0",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "^4.0.17"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  }
}
