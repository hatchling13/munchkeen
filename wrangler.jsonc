{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "munchkeen-docs",
  "main": "./workers/docs.js",
  "compatibility_date": "2026-03-29",
  "routes": [
    {
      "pattern": "munchkeen.hatchling.dev",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dev/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
